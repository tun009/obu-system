// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
}

enum VehicleStatus {
  ONLINE
  OFFLINE
  STOPPED
  PARKED
  LOST_SIGNAL
  RUNNING
}

model Vehicle {
  id             Int           @id @default(autoincrement())
  imei           String        @unique // Mã MQTT Topic
  licensePlate   String?       @map("license_plate")
  type           String?
  
  currentStatus  VehicleStatus @default(OFFLINE) @map("current_status")
  
  // Lưu tọa độ GPS dưới định dạng hệ toạ độ WGS-84 (SRID 4326)
  currentLocation Unsupported("geometry(Point, 4326)")? @map("current_location")
  
  engineRpm      Int?          @map("engine_rpm")
  speedKmh       Float?        @map("speed_kmh")
  fuelLevel      Float?        @map("fuel_level")
  coolantTemp    Float?        @map("coolant_temp")
  throttle       Float?        @map("throttle")
  direction      Float?        @map("direction")
  
  lastUpdatedAt  DateTime      @default(now()) @updatedAt @map("last_updated_at")

  journeyLogs    JourneyLog[]

  @@map("vehicles")
}

model JourneyLog {
  // TimescaleDB hypertable — không dùng @id vì PK quản lý bằng migration SQL
  // Hypertable tự động partition theo timestamp (1 chunk/ngày)
  timestamp     DateTime      @default(now())
  
  vehicleId     Int           @map("vehicle_id")
  vehicle       Vehicle       @relation(fields: [vehicleId], references: [id], onDelete: Cascade)
  
  // Lưu tọa độ điểm cho mỗi log
  location      Unsupported("geometry(Point, 4326)")?
  
  speed         Float?
  rpm           Int?
  fuelLevel     Float?        @map("fuel_level")
  coolantTemp   Float?        @map("coolant_temp")
  throttle      Float?        @map("throttle")
  direction     Float?        @map("direction")
  engineStatus  Boolean?      @map("engine_status")

  @@index([timestamp])
  @@index([vehicleId, timestamp])
  @@map("journey_logs")
  @@ignore // Prisma không quản lý PK trực tiếp — dùng raw SQL migration
}
