# ============================================================
# OBU System - Production Environment Variables
# Copy file này thành .env rồi điền giá trị thực
# KHÔNG commit file .env lên Git
# ============================================================

# Server
SERVER_IP=203.0.113.10       # VD: 203.0.113.10

# PostgreSQL
DB_USER=admin
DB_PASSWORD=password123             
DB_NAME=obu_database

# MQTT Broker (giữ nguyên nếu dùng cùng broker hiện tại)
MQTT_HOST=tcp://0.tcp.ap.ngrok.io
MQTT_PORT=16386
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_CLIENT_ID=obu_backend_listener
